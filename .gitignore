# ── Training artifacts ────────────────────────────────────────────────
# Anything generated by training runs — too big, regeneratable from
# `scripts/prepare_data.py` + `training/train_tiny_hetmoe.py`.
runs/
logs/

# Tokenized corpus (regenerate via scripts/prepare_data.py).
data/train.bin
data/val.bin

# Old path (pre-rename to docs/) — gitignore for safety
ui/tiny.bin
ui/tiny_v2.bin
# Note: docs/tiny.bin IS committed (~15 MB packed) so GitHub Pages
# serves the model directly. Re-export with:
#   python3 scripts/export_model.py --ckpt <ckpt.pt> --out docs/tiny.bin

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.python-version

