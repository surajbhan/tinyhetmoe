# ── Training artifacts ────────────────────────────────────────────────
# Anything generated by training runs — too big, regeneratable from
# `scripts/prepare_data.py` + `training/train_tiny_hetmoe.py`.
runs/
logs/

# Tokenized corpus (regenerate via scripts/prepare_data.py).
data/train.bin
data/val.bin

# Trained model weights — pushed separately as a release artifact once
# v2 finishes. Do NOT commit until then. (`tiny.meta.json` is fine,
# it's just a few hundred bytes of metadata.)
ui/tiny.bin
ui/tiny_v2.bin

