# ── Training artifacts ────────────────────────────────────────────────
# Anything generated by training runs — too big, regeneratable from
# `scripts/prepare_data.py` + `training/train_tiny_hetmoe.py`.
runs/
logs/

# Tokenized corpus (regenerate via scripts/prepare_data.py).
data/train.bin
data/val.bin

# Trained model weights — committed to docs/tiny.bin once v2 finishes
# (so GitHub Pages serves it directly). Until then, gitignore so we
# don't accidentally check in the in-flight v1 weights.
docs/tiny.bin
docs/tiny_v2.bin
# Old path (pre-rename to docs/) — keep for safety
ui/tiny.bin
ui/tiny_v2.bin

