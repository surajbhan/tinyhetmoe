# ── Training artifacts ────────────────────────────────────────────────
# Anything generated by training runs — too big, regeneratable from
# `scripts/prepare_data.py` + `training/train_tiny_hetmoe.py`.
runs/
logs/

# v7 tokenized corpora — produced by prepare_data_v7.py, regenerable.
data_v7/

# Tokenized corpora, per-token embeddings, and intermediate artifacts.
# All regeneratable from scripts/{prepare_data*,make_*meaning_axes,
# build_tool_corpus,tokenize_tool_corpus,patch_vocab_for_chatml,
# train_domain_classifier}.py.
data/*.bin
data/*.npy
data/*.bak
data/*.bak.bin
data/tool_corpus_chatml.txt
data/tool_corpus_stats.json
data/domain_classifier_*.pt

# Old path (pre-rename to docs/) — gitignore for safety
ui/tiny.bin
ui/tiny_v2.bin
# Note: docs/tiny.bin IS committed (~15 MB packed) so GitHub Pages
# serves the model directly. Re-export with:
#   python3 scripts/export_model.py --ckpt <ckpt.pt> --out docs/tiny.bin

# Stitch bundles — per-expert weights.
#   .bin     — uncompressed, NOT committed (regenerate via build_stitch_bundle.py)
#   .bin.gz  — gzipped for browser streaming, IS committed so the demo
#              works directly off the GitHub Pages serve. The browser
#              uses DecompressionStream("gzip") to inflate while loading.
#   .meta.json — stats only, not load-bearing for the demo
docs/stitch_*/*.bin
docs/stitch_*/*.meta.json

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.python-version

# ── Rust / WASM build cache ──────────────────────────────────────────
wasm/target/
wasm/Cargo.lock

# ── Node / JS build cache ────────────────────────────────────────────
node_modules/
*.log

# ── Editor / OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# ── Reference / scratch ──────────────────────────────────────────────
wasm/src.orig/
wasm/Cargo.toml.orig
*.tmp.*

